# Razorpay — copy to .env.local and fill from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: only needed if you do not use keyId from /api/create-payment (local tooling)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Sheets — vote page (/vote). Share the sheet with your service account email (Editor).
# GOOGLE_CREDENTIALS is the same JSON used by other forms in this project.
GOOGLE_VOTE_SHEET_ID=

# ── AI Counselor (/api/chat) ─────────────────────────────────────────────────
# Directory containing the canonical warehouse CSVs. REQUIRED for /api/chat.
# In Docker this defaults to /app/data (baked into the image); leave blank to use it.
CYC_DATA_DIR=
# OpenAI (or OpenAI-compatible) — enables the LLM reasoning layer. Without a key
# the counselor still answers, deterministically, from warehouse evidence.
# NEVER commit a real key here. Put it in .env.local (local) or the Azure
# Container App secret store (production). This file is a template only.
OPENAI_API_KEY=
# Model — for Azure OpenAI this is the DEPLOYMENT name (not the base model id).
OPENAI_MODEL=gpt-4.1
#
# ── Native Azure OpenAI (this project's production setup) ────────────────────
# Set the resource endpoint + api-version. The client then uses api-key auth and
# the https://<res>.openai.azure.com/openai/deployments/<OPENAI_MODEL>/chat/completions
# URL automatically. OPENAI_API_KEY holds the Azure resource key.
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# OPENAI_API_VERSION=2024-10-21
#
# ── Public OpenAI / OpenAI-compatible gateway (Bearer auth) ─────────────────
# Leave AZURE_OPENAI_ENDPOINT unset; optionally point at a compatible base URL:
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# OPENAI_TIMEOUT_MS=30000
# OPENAI_MAX_OUTPUT_TOKENS=1024
# COUNSELOR_TIMEOUT_MS=45000
