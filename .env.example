# Razorpay — copy to .env.local and fill from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: only needed if you do not use keyId from /api/create-payment (local tooling)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Sheets — vote page (/vote). Share the sheet with your service account email (Editor).
# GOOGLE_CREDENTIALS is the same JSON used by other forms in this project.
GOOGLE_VOTE_SHEET_ID=

# Private analytics dashboard (/insights). Long random secret — the shareable link is
# https://<your-domain>/insights/<DASHBOARD_TOKEN>. Rotate this to revoke all access.
# Generate a new one with:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DASHBOARD_TOKEN=

# GA4 numeric property ID (Admin → Property Settings), NOT the G-XXXX measurement id.
# Powers the "Site Visits / Unique Visitors" tiles on /insights via the GA Data API.
# Also: enable the "Google Analytics Data API" and add the GOOGLE_CREDENTIALS service
# account as a Viewer on the GA4 property.
GA4_PROPERTY_ID=
