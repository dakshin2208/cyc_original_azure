# Razorpay — copy to .env.local and fill from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: only needed if you do not use keyId from /api/create-payment (local tooling)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Sheets — vote page (/vote). Share the sheet with your service account email (Editor).
# GOOGLE_CREDENTIALS is the same JSON used by other forms in this project.
GOOGLE_VOTE_SHEET_ID=

# ── AI Counselor (/api/chat) ─────────────────────────────────────────────────
# Directory containing the canonical warehouse CSVs. REQUIRED for /api/chat.
# In Docker this defaults to /app/data (baked into the image); leave blank to use it.
CYC_DATA_DIR=
# OpenAI (or OpenAI-compatible) — enables the LLM reasoning layer. Without a key
# the counselor still answers, deterministically, from warehouse evidence.
# NEVER commit a real key here. Put it in .env.local (local) or the Azure
# Container App secret store (production). This file is a template only.
OPENAI_API_KEY=
# Model — for Azure OpenAI this is the DEPLOYMENT name (not the base model id). It MUST
# match a deployment that exists on the Azure resource, else Azure returns 404
# DeploymentNotFound. Set to your actual deployment (e.g. gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini
# Preferred (standard Azure) way to set the deployment name; takes priority over
# OPENAI_MODEL when present. Set this to the deployment that exists on your resource.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
#
# ── Native Azure OpenAI (this project's production setup) ────────────────────
# Set the resource endpoint + api-version. The client then uses api-key auth and
# the https://<res>.openai.azure.com/openai/deployments/<deployment>/chat/completions
# URL automatically. OPENAI_API_KEY holds the Azure resource key.
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# OPENAI_API_VERSION=2024-10-21
#
# ── Public OpenAI / OpenAI-compatible gateway (Bearer auth) ─────────────────
# Leave AZURE_OPENAI_ENDPOINT unset; optionally point at a compatible base URL:
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# OPENAI_TIMEOUT_MS=30000
# OPENAI_MAX_OUTPUT_TOKENS=1024
# COUNSELOR_TIMEOUT_MS=45000

# Private analytics dashboard (/insights). Long random secret — the shareable link is
# https://<your-domain>/insights/<DASHBOARD_TOKEN>. Rotate this to revoke all access.
# Generate a new one with:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DASHBOARD_TOKEN=

# GA4 numeric property ID (Admin → Property Settings), NOT the G-XXXX measurement id.
# Powers the "Site Visits / Unique Visitors" tiles on /insights via the GA Data API.
# Also: enable the "Google Analytics Data API" and add the GOOGLE_CREDENTIALS service
# account as a Viewer on the GA4 property.
GA4_PROPERTY_ID=
