# Keep the build context small and avoid leaking local artifacts/secrets.
node_modules
.next
out
build
.git
.github
.vscode
.idea

# Local env / secrets — never send to the build context.
.env
.env.*
!.env.example

# Package-manager cruft (this project builds with npm).
.pnpm-store
pnpm-lock.yaml

# Docs & tooling not needed at runtime.
*.md
!README.md
netlify.toml
Dockerfile
.dockerignore

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
